{
  "name": "moses-cli",
  "version": "1.3.1",
  "description": "Thou shalt not break production",
  "type": "module",
  "bin": {
    "moses": "./dist/src/index.js",
    "lourran": "./dist/src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./dist/src/index.js",
    "test": "echo \"No tests specified\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check-types": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm check-types",
    "build": "rm -rf dist && tsc && mkdir -p dist/src/prompts && cp src/prompts/*.md dist/src/prompts/",
    "prepare": "husky"
  },
  "keywords": [
    "gitlab",
    "merge-request",
    "code-review",
    "ai",
    "cli",
    "copilot",
    "claude"
  ],
  "author": "stanleygomes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stanleygomes/moses-cli"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "axios": "^1.11.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "dayjs": "^1.11.13",
    "figlet": "^1.8.2",
    "ora": "^8.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
